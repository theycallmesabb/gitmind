# Server config
PORT=8082
DEV_MODE=true
JWT_SECRET=super-secret-jwt-key-change-in-prod

# Database configs (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5435/github_assistant?sslmode=disable

# Cache configs (Redis)
REDIS_ADDR=localhost:6379
REDIS_PASS=

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# AI APIs (Provide at least one)
GEMINI_API_KEY=
OPENAI_API_KEY=

# GitHub API Token (Optional, increases API limits)
GITHUB_TOKEN=

# Google OAuth credentials (Optional, required for production login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8082/api/auth/callback/google
